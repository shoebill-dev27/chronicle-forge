# Chronicle Forge environment template.
# Copy to .env and fill in real values. Never commit .env.

# Anthropic API (used only for the 5 bounded AI call sites; see docs/design.md section 12).
ANTHROPIC_API_KEY=

# Model selection (defaults applied in code if unset).
CF_NARRATIVE_MODEL=claude-opus-4-8
CF_DECISION_MODEL=claude-haiku-4-5-20251001

# World lifespan in years. Dev/CI uses 40 for fast iteration; production uses 200.
CF_WORLD_MAX_YEARS=40

# Per-life AI call budget guard (0 disables AI; rules-only fallback).
CF_AI_CALL_BUDGET=8

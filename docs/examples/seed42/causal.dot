  "her:seed-0012" [shape=doubleoctagon, style=filled, fillcolor=palegreen, label="school\nscore 810"];
  "her:seed-0027" [shape=doubleoctagon, style=filled, fillcolor=palegreen, label="institution\nscore 510"];
  "her:seed-0038" [shape=doubleoctagon, style=filled, fillcolor=palegreen, label="thought\nscore 510"];
